# MongoDB Atlas connection string for blast-prod (read-only user)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/blast-prod

# (Opcional) Microsoft Clarity Data Export API token
# Si lo configuras, el dashboard actualizará automáticamente los datos de comportamiento
# Límite: 10 requests/día, máximo 3 días hacia atrás
CLARITY_API_TOKEN=
